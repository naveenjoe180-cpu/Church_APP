rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function approvalStatus() {
      return hasUserDoc() ? currentUser().data.approvalStatus : "";
    }

    function isApproved() {
      return approvalStatus() == "approved";
    }

    function hasRole(roleKey) {
      return hasUserDoc() && roleKey in currentUser().data.roleFlags && currentUser().data.roleFlags[roleKey] == true;
    }

    function belongsToChurch(churchId) {
      return hasUserDoc() && churchId in currentUser().data.churchAccess && currentUser().data.churchAccess[churchId] == true;
    }

    function belongsToTeam(teamId) {
      return hasUserDoc() && teamId in currentUser().data.teamAccess && currentUser().data.teamAccess[teamId] == true;
    }

    function isNetworkSuperAdmin() {
      return hasRole("networkSuperAdmin");
    }

    function isChurchAdmin(churchId) {
      return isNetworkSuperAdmin() || (hasRole("churchAdmin") && belongsToChurch(churchId));
    }

    function isPastor(churchId) {
      return isNetworkSuperAdmin() || (hasRole("pastor") && belongsToChurch(churchId));
    }

    function isTeamLeader(churchId, teamId) {
      return isNetworkSuperAdmin()
        || isChurchAdmin(churchId)
        || (hasRole("teamLeader") && belongsToChurch(churchId) && belongsToTeam(teamId));
    }

    match /churches/{churchId} {
      allow read: if resource.data.isPublic == true || (isApproved() && belongsToChurch(churchId)) || isNetworkSuperAdmin();
      allow write: if isChurchAdmin(churchId);
    }

    match /teams/{teamId} {
      allow read: if isApproved();
      allow write: if isNetworkSuperAdmin()
        || (request.resource.data.churchId is string && isChurchAdmin(request.resource.data.churchId));
    }

    match /users/{uid} {
      allow create: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          request.resource.data.primaryChurchId is string
          && isChurchAdmin(request.resource.data.primaryChurchId)
        )
      );
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && (
            isPastor(resource.data.primaryChurchId)
            || isChurchAdmin(resource.data.primaryChurchId)
          )
        )
      );
      allow update: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && isChurchAdmin(resource.data.primaryChurchId)
        )
        || (
          request.resource.data.primaryChurchId is string
          && isChurchAdmin(request.resource.data.primaryChurchId)
        )
      );
      allow delete: if isNetworkSuperAdmin();
    }

    match /userPrivateProfiles/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && (
            isPastor(resource.data.primaryChurchId)
            || isChurchAdmin(resource.data.primaryChurchId)
          )
        )
      );
      allow write: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.primaryChurchId)
      );
    }

    match /accessRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.requestedChurchId)
      );
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.requestedChurchId)
      );
      allow delete: if isNetworkSuperAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if resource.data.isPublic == true
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && (
            resource.data.scopeChurchId == null
            || belongsToChurch(resource.data.scopeChurchId)
          )
          && (
            resource.data.scopeTeamId == null
            || belongsToTeam(resource.data.scopeTeamId)
          )
        );
      allow write: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.scopeChurchId)
        || (
          request.resource.data.scopeChurchId is string
          && request.resource.data.scopeTeamId is string
          && isTeamLeader(request.resource.data.scopeChurchId, request.resource.data.scopeTeamId)
        )
      );
    }

    match /events/{eventId} {
      allow read: if resource.data.isPublic == true
        || isNetworkSuperAdmin()
        || (isApproved() && belongsToChurch(resource.data.churchId));
      allow write: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.churchId)
        || (
          request.resource.data.teamId is string
          && isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
        )
      );
    }

    match /scheduleAssignments/{assignmentId} {
      allow read: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isTeamLeader(resource.data.churchId, resource.data.teamId)
        || resource.data.assignedUserId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.churchId)
        || isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
      );
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.churchId)
        || isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
        || (
          resource.data.assignedUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseStatus', 'respondedAt', 'updatedAt'])
          && (
            request.resource.data.responseStatus == 'accepted'
            || request.resource.data.responseStatus == 'declined'
          )
        )
      );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isTeamLeader(resource.data.churchId, resource.data.teamId)
      );
    }

    match /prayerRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if resource.data.status == "approved"
        || isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isPastor(resource.data.churchId);
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isPastor(resource.data.churchId)
      );
    }

    match /documents/{documentId} {
      allow read: if resource.data.visibility == "public"
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && belongsToChurch(resource.data.churchId)
          && (
            resource.data.teamId == null
            || belongsToTeam(resource.data.teamId)
          )
        );
      allow write: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchAdmin(request.resource.data.churchId)
        || (
          request.resource.data.teamId is string
          && isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
        )
      );
    }

    match /auditLogs/{logId} {
      allow read, write: if isNetworkSuperAdmin();
    }
  }
}

