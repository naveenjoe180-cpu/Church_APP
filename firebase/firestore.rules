rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function approvalStatus() {
      return hasUserDoc() ? currentUser().data.approvalStatus : "";
    }

    function isApproved() {
      return approvalStatus() == "approved";
    }

    function pendingChurchId() {
      return hasUserDoc() && currentUser().data.pendingChurchId is string
        ? currentUser().data.pendingChurchId
        : "";
    }

    function hasRole(roleKey) {
      return hasUserDoc() && roleKey in currentUser().data.roleFlags && currentUser().data.roleFlags[roleKey] == true;
    }

    function belongsToChurch(churchId) {
      return hasUserDoc() && churchId in currentUser().data.churchAccess && currentUser().data.churchAccess[churchId] == true;
    }

    function belongsToTeam(teamId) {
      return hasUserDoc() && teamId in currentUser().data.teamAccess && currentUser().data.teamAccess[teamId] == true;
    }

    function isNetworkSuperAdmin() {
      return hasRole("networkSuperAdmin");
    }

    function isChurchAdmin(churchId) {
      return isNetworkSuperAdmin() || (hasRole("churchAdmin") && belongsToChurch(churchId));
    }

    function isAnyChurchAdmin() {
      return hasRole("churchAdmin");
    }

    function isPastor(churchId) {
      return isNetworkSuperAdmin() || (hasRole("pastor") && belongsToChurch(churchId));
    }

    function isChurchManager(churchId) {
      return isNetworkSuperAdmin()
        || ((hasRole("churchAdmin") || hasRole("pastor")) && belongsToChurch(churchId));
    }

    function isAnyChurchManager() {
      return hasRole("churchAdmin") || hasRole("pastor");
    }

    function isTeamLeader(churchId, teamId) {
      return isNetworkSuperAdmin()
        || isChurchAdmin(churchId)
        || ((hasRole("teamLeader") || hasRole("pastor")) && belongsToChurch(churchId) && belongsToTeam(teamId));
    }

    function targetHasRole(userData, roleKey) {
      return userData.roleFlags is map
        && roleKey in userData.roleFlags
        && userData.roleFlags[roleKey] == true;
    }

    function canDeleteManagedUser(uid, userData) {
      return request.auth.uid != uid
        && (
          isNetworkSuperAdmin()
          || (
            userData.primaryChurchId is string
            && isChurchManager(userData.primaryChurchId)
            && !targetHasRole(userData, "networkSuperAdmin")
            && !targetHasRole(userData, "churchAdmin")
          )
        );
    }

    function isPastorManagedUserWrite(userData) {
      return userData.primaryChurchId is string
        && isPastor(userData.primaryChurchId)
        && userData.roleFlags is map
        && !targetHasRole(userData, "networkSuperAdmin")
        && !targetHasRole(userData, "churchAdmin")
        && !targetHasRole(userData, "pastor");
    }

    function isSafeSelfUserCreate(uid) {
      return request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.primaryChurchId is string
        && request.resource.data.pendingChurchId is string
        && request.resource.data.primaryChurchId == request.resource.data.pendingChurchId
        && request.resource.data.approvalStatus == "pending"
        && request.resource.data.roleFlags is map
        && request.resource.data.roleFlags.keys().hasOnly(["member"])
        && request.resource.data.roleFlags.member == true
        && request.resource.data.churchAccess is map
        && request.resource.data.churchAccess.keys().size() == 0
        && request.resource.data.teamAccess is map
        && request.resource.data.teamAccess.keys().size() == 0;
    }

    function isSafeSelfUserUpdate(uid) {
      return request.auth.uid == uid
        && resource.data.uid == uid
        && resource.data.approvalStatus != "approved"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "photoUrl",
          "phoneNumber",
          "primaryChurchId",
          "pendingChurchId",
          "updatedAt"
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.approvalStatus == resource.data.approvalStatus
        && request.resource.data.roleFlags == resource.data.roleFlags
        && request.resource.data.churchAccess == resource.data.churchAccess
        && request.resource.data.teamAccess == resource.data.teamAccess
        && request.resource.data.primaryChurchId is string
        && request.resource.data.pendingChurchId is string
        && request.resource.data.primaryChurchId == request.resource.data.pendingChurchId;
    }

    function hasValidNotificationChurchIds(churchIds) {
      return churchIds is list
        && churchIds.size() <= 1
        && (
          churchIds.size() == 0
          || belongsToChurch(churchIds[0])
          || churchIds[0] == pendingChurchId()
        );
    }

    function isSafeAccessRequestCreate() {
      return request.resource.data.uid == request.auth.uid
        && (!hasUserDoc() || approvalStatus() == "rejected")
        && request.resource.data.email is string
        && request.resource.data.fullName is string
        && request.resource.data.requestedChurchId is string
        && request.resource.data.churchId == request.resource.data.requestedChurchId
        && request.resource.data.status == "pending"
        && request.resource.data.signInMethod == "google"
        && request.resource.data.requestedRoles is list
        && request.resource.data.requestedRoles.size() == 1
        && request.resource.data.requestedRoles[0] == "member";
    }

    match /churches/{churchId} {
      allow read: if resource.data.isPublic == true || (isApproved() && belongsToChurch(churchId)) || isNetworkSuperAdmin();
      allow write: if isNetworkSuperAdmin();
    }

    match /teams/{teamId} {
      allow read: if isApproved();
      allow write: if isNetworkSuperAdmin()
        || (request.resource.data.churchId is string && isChurchManager(request.resource.data.churchId));
    }

    match /users/{uid} {
      allow create: if isSignedIn() && (
        isSafeSelfUserCreate(uid)
        || isNetworkSuperAdmin()
        || (
          request.resource.data.primaryChurchId is string
          && isChurchManager(request.resource.data.primaryChurchId)
        )
      );
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && resource != null
          && resource.data.primaryChurchId is string
          && belongsToChurch(resource.data.primaryChurchId)
          && resource.data.approvalStatus == "approved"
        )
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && (
            isPastor(resource.data.primaryChurchId)
            || isChurchAdmin(resource.data.primaryChurchId)
            || (hasRole("teamLeader") && belongsToChurch(resource.data.primaryChurchId))
          )
        )
      );
      allow update: if isSignedIn() && (
        isSafeSelfUserUpdate(uid)
        || isNetworkSuperAdmin()
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && isChurchManager(resource.data.primaryChurchId)
        )
        || (
          request.resource.data.primaryChurchId is string
          && isChurchManager(request.resource.data.primaryChurchId)
        )
      );
      allow delete: if isSignedIn()
        && resource != null
        && canDeleteManagedUser(uid, resource.data);
    }

    match /userPrivateProfiles/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isNetworkSuperAdmin()
        || (
          resource != null
          && resource.data.primaryChurchId is string
          && (
            isPastor(resource.data.primaryChurchId)
            || isChurchAdmin(resource.data.primaryChurchId)
          )
        )
      );
      allow create, update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || (
          request.resource.data.primaryChurchId is string
          && isChurchManager(request.resource.data.primaryChurchId)
        )
      );
      allow delete: if isSignedIn()
        && resource != null
        && canDeleteManagedUser(uid, resource.data);
    }

    match /accessRequests/{requestId} {
      allow create: if isSignedIn() && isSafeAccessRequestCreate();
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || isNetworkSuperAdmin()
        || isChurchManager(resource.data.requestedChurchId)
      );
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.requestedChurchId)
      );
      allow delete: if isNetworkSuperAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if resource.data.isPublic == true
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && (
            resource.data.scopeChurchId == null
            || belongsToChurch(resource.data.scopeChurchId)
          )
        );
      allow create, update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(request.resource.data.scopeChurchId)
      );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.scopeChurchId)
      );
    }

    match /events/{eventId} {
      allow read: if resource.data.isPublic == true
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && (
            resource.data.scopeType == "network"
            || belongsToChurch(resource.data.churchId)
          )
        );
      allow create, update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || (
          request.resource.data.scopeType != "network"
          && isChurchManager(request.resource.data.churchId)
        )
      );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || (
          resource.data.scopeType != "network"
          && isChurchManager(resource.data.churchId)
        )
      );
    }

    match /commonMeetingCancellations/{cancellationId} {
      allow read: if isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
        || (isApproved() && belongsToChurch(resource.data.churchId));
      allow create: if isSignedIn()
        && request.resource.data.churchId is string
        && (
          isNetworkSuperAdmin()
          || isChurchManager(request.resource.data.churchId)
        );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
      );
    }

    match /churchSpecificMeetingCancellations/{cancellationId} {
      allow read: if isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
        || (isApproved() && belongsToChurch(resource.data.churchId));
      allow create: if isSignedIn()
        && request.resource.data.churchId is string
        && (
          isNetworkSuperAdmin()
          || isChurchManager(request.resource.data.churchId)
        );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
      );
    }

    match /scheduleAssignments/{assignmentId} {
      allow read: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
        || isTeamLeader(resource.data.churchId, resource.data.teamId)
        || (
          isApproved()
          && belongsToChurch(resource.data.churchId)
          && (
            (resource.data.teamId is string && belongsToTeam(resource.data.teamId))
            || (resource.data.teamName is string && belongsToTeam(resource.data.teamName))
          )
        )
        || resource.data.assignedUserId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(request.resource.data.churchId)
        || isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
      );
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(request.resource.data.churchId)
        || isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
        || (
          resource.data.assignedUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseStatus', 'respondedAt', 'updatedAt'])
          && (
            request.resource.data.responseStatus == 'accepted'
            || request.resource.data.responseStatus == 'declined'
          )
        )
      );
      allow delete: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
        || isTeamLeader(resource.data.churchId, resource.data.teamId)
      );
    }

    match /prayerRequests/{requestId} {
      allow create: if isSignedIn()
        && isApproved()
        && request.resource.data.churchId is string
        && belongsToChurch(request.resource.data.churchId)
        && request.resource.data.submittedByUid == request.auth.uid;
      allow read: if (
          resource.data.status == "approved"
          && isApproved()
          && belongsToChurch(resource.data.churchId)
        )
        || (
          isSignedIn()
          && resource.data.submittedByUid == request.auth.uid
        )
        || isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isPastor(resource.data.churchId);
      allow update: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
      );
      allow delete: if isSignedIn() && (
        resource.data.submittedByUid == request.auth.uid
        || isNetworkSuperAdmin()
        || isChurchManager(resource.data.churchId)
      );
    }

    match /prayerResponses/{responseId} {
      allow create, update: if isSignedIn()
        && isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.prayerRequestId is string
        && request.resource.data.churchId is string
        && belongsToChurch(request.resource.data.churchId)
        && request.resource.data.status == "prayed";
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isNetworkSuperAdmin()
        || isChurchAdmin(resource.data.churchId)
        || isPastor(resource.data.churchId)
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /documents/{documentId} {
      allow read: if resource.data.visibility == "public"
        || isNetworkSuperAdmin()
        || (
          isApproved()
          && belongsToChurch(resource.data.churchId)
          && (
            resource.data.teamId == null
            || belongsToTeam(resource.data.teamId)
          )
        );
      allow write: if isSignedIn() && (
        isNetworkSuperAdmin()
        || isChurchManager(request.resource.data.churchId)
        || (
          request.resource.data.teamId is string
          && isTeamLeader(request.resource.data.churchId, request.resource.data.teamId)
        )
      );
    }

    match /notificationDevices/{deviceId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isNetworkSuperAdmin()
      );
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.channel == "expo"
        && request.resource.data.token is string
        && request.resource.data.permissionState is string
        && request.resource.data.deviceLabel is string
        && request.resource.data.enabled == true
        && request.resource.data.approvalStatus == approvalStatus()
        && hasValidNotificationChurchIds(request.resource.data.churchIds);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.audienceUserId == request.auth.uid
        || isNetworkSuperAdmin()
        || (
          resource.data.audienceChurchId is string
          && (
            isChurchManager(resource.data.audienceChurchId)
            || isPastor(resource.data.audienceChurchId)
          )
        )
      );
      allow write, delete: if false;
    }

    match /auditLogs/{logId} {
      allow read, write: if isNetworkSuperAdmin();
    }
  }
}

